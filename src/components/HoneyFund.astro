---
import Card from "./Card.astro";
import { getEventData } from "../data/eventData";

const { HoneyFund } = getEventData();
const { cards = [] } = getEventData();
---


<section id="HoneyFund">

<div class="max-w-4xl mx-auto p-10">
        <p
        class="text-sm uppercase tracking-[0.35em] p-3"
        style="color: var(--color-muted);"
    >
        {HoneyFund.chapterLabel}
    </p>        
        <h2 class="text-4xl lg:text-7xl tracking-tight font-(--font-display)"
        style="color: var(--color-primary); p-3">{HoneyFund.heading}</h6>
        <p
            class="text-lg leading-relaxed whitespace-pre-line font-(--font-sans) p-3"
            style="color: var(--color-primary);"
            >
            {HoneyFund.body}
        </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
            cards.map((card) => (
                <a
                    href={card.href} target="_blank" title={card.title}
                    class="group block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
                >
                    <Card
                        imageAlt={card.imageAlt}
                        title={card.title}
                    />
                </a>
            ))
        }
    </div>
</div>
</section>