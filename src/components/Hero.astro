---
import { getEventData } from "../data/eventData";
import { Icon } from 'astro-icon/components';

const { hero } = getEventData();

---

<section
    id="hero"
    class="hero overflow-hidden [&_.section__inner]:max-w-none [&_.section__inner]:p-0 bg-[url('../assets/wildflowers.jpg')] bg-fixed"
    style={`
        background-size: cover;
        background-position: center;
        background-color: var(--color-primary);
          background-blend-mode: soft-light;
    `}
>
    <div class="w-full px-6 py-20 md:py-28 lg:py-36">
        <div
            class="mx-auto flex w-full max-w-6xl flex-col gap-12 md:flex-row md:items-end"
        >
            <div class="space-y-6 text-left md:max-w-3xl">
                <p
                    class="text-xs uppercase tracking-[0.65em]"
                    style="color: var(--color-secondary); opacity: 0.7;"
                >
                    {hero.tagline}
                </p>
                <h1
                    class="font-display text-[clamp(3.5rem,8vw,6.5rem)] leading-[0.88] drop-shadow-md"
                    id="hero-heading"
                    data-hero-title={hero.title}
                    style="color: var(--color-background);"
                >
                Camille <span class="font-serif font-light text-sm md:text-base align-[7px] md:align-[20px] relative left-1">&</span> Melissa
                </h1>
                <p
                    class="max-w-2xl text-base leading-relaxed md:text-lg"
                    style="color: var(--color-secondary); opacity: 0.9;"
                >
                    {hero.description}
                </p>
            </div>

            <div class="text-left md:text-right ">
                <p
                    class="text-xs uppercase tracking-[0.45em]"
                    style="color: var(--color-secondary); opacity: 0.7;"
                >
                    {hero.weekday}
                </p>
                <p
                    class="font-display text-4xl uppercase tracking-[0.2em]"
                    style="color: var(--color-background);"
                >
                    {hero.dateDisplay}
                </p>
                <p
                    class="mt-4 text-sm font-semibold uppercase tracking-[0.35em]"
                    style="color: var(--color-secondary); opacity: 0.7;"
                >
                    <a href={hero.href} title="Maps" target="_blank">
                        {hero.location}
                    </a></p>
                </p>
                <p
                    class="text-sm font-semibold uppercase tracking-[0.35em]"
                    style="color: var(--color-secondary); opacity: 0.7;"
                >
                    <a href={hero.href} title="Maps" target="_blank">
                        {hero.location_2}
                    </a></p>
                </p>

                <p
                    class="text-xs uppercase mt-2"
                    style="color: var(--color-secondary); opacity: 0.7;"
                >
                    <a href={hero.href} title="Maps" target="_blank">                
                        {hero.address}
                    </a>
                </p>
            </div>
        </div>
    </div>
</section>


