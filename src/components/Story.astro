---
import { Image } from "astro:assets";
import { getEventData } from "../data/eventData";

const { story } = getEventData();
const highlights = story.highlights ?? [];
const imageAlt = story.imageAlt ?? "Our story together";

---

<section 
    id="story"
    class="py-24 px-6"
    style="background-color: var(--color-background-secondary); color: var(--color-secondary);"
>
    <div
        class="mx-auto flex max-w-6xl flex-col gap-12 md:flex-row md:items-center"
    >
        <div class="md:w-7/12 space-y-6">
            <p
                class="text-sm uppercase tracking-[0.35em] font-(--font-sans)"
                style="color: var(--color-secondary); opacity: 0.7;"
            >
                {story.chapterLabel}
            </p>
            <h2
                class="text-4xl sm:text-5xl tracking-tight font-(--font-display)"
                style="color: var(--color-secondary);"
            >
                {story.heading}
            </h2>
            <p
                class="text-lg leading-relaxed whitespace-pre-line font-(--font-sans)"
                style="color: var(--color-secondary); opacity: 0.8;"
            >
                {story.body}
            </p>

            <div
                class="mt-6 flex flex-wrap gap-3 text-sm font-(--font-sans)"
                style="color: var(--color-secondary); opacity: 0.7;"
            >
                {
                    highlights.map((highlight) => (
                        <span
                            class="inline-flex items-center gap-2 rounded-full border px-4 py-2"
                            style="border-color: var(--color-text-dark);"
                        >
                            {highlight}
                        </span>
                    ))
                }
            </div>
        </div>



        <div class="md:w-5/12">
            <div class="relative">
                <div class="relative rounded-4xl border p-4 backdrop-blur">
                    <Image src="https://i.postimg.cc/Y0Ds5W04/vadim-paripa-unsplash.jpg" width="100%" height="100%" alt="my image"
                        class="h-full w-full rounded-3xl object-cover"
                        loading="lazy"
                        format="webp" />
                </div>
            </div>
        </div> 
